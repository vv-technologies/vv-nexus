// 1. REPLICARE & PATCH: vv-repos.html (Buton la 150px, z-index suprem)
const setupNexusEnvironment = () => {
    // Curățare DOM existent pentru a preveni duplicarea
    const oldBtn = document.getElementById('FixedSettingsBtn');
    if (oldBtn) oldBtn.remove();

    const btn = document.createElement('button');
    btn.id = 'FixedSettingsBtn';
    btn.innerHTML = '⚙️';
    btn.style.cssText = `
        position: fixed; 
        top: 150px; 
        right: 20px; 
        z-index: 9999999; 
        background: #050507; 
        border: 2px solid #D4AF37; 
        color: #D4AF37; 
        padding: 15px; 
        border-radius: 50%; 
        font-size: 20px; 
        cursor: pointer;
        box-shadow: 0 0 20px rgba(212,175,55,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
    `;
    
    btn.onclick = (e) => {
        e.preventDefault();
        const token = prompt("Arhitectule, introdu cheia de acces:");
        if (token) {
            localStorage.setItem('vv_secure_vault', btoa(token));
            alert("Acces autorizat în VV-NEXUS.");
        }
    };
    
    document.body.appendChild(btn);
    console.log("VV-NEXUS: Environment Initialized at 150px.");
};

// 2. CONEXIUNE: Toate link-urile redirectate către /vv-nexus/
// 3. PUSH: Execuție în curs către repo-ul vv-nexus
setupNexusEnvironment();